# The Junkyard / FEEDFACE server config (NON-SECRET). Copy to feedface.env on the VPS.
# The private key is intentionally NOT here — the server needs only the PUBLIC address.
# The sealed private key lives offline (secrets vault: junkyard_wallet_key), used only to
# move collected USDC, never by the server.

FEEDFACE_DATA_DIR=/opt/feedface/data

# Payment mode: off (dev) | trust (logic test, no crypto) | x402 (real)
FEEDFACE_X402_MODE=off

FEEDFACE_PRICE_USD=0.05
FEEDFACE_WALLET=0x3A56664695c06A6a36c97fe3029303f3Feed4bFb   # PUBLIC receiving address

# CAIP-2 chain id, not the human alias — the x402 lib matches on this string exactly.
# Base mainnet = eip155:8453 (live default below). Base Sepolia testnet = eip155:84532.
FEEDFACE_NETWORK=eip155:8453

# USDC contract per chain — mainnet (Circle's native Base USDC) shown; Sepolia test USDC
# is 0x036CbD53842c5426634e7929541eC2318f3dCF7e.
FEEDFACE_USDC_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# EIP-712 signing domain, read from the asset contract's own name()/version(). These are
# NOT both "USDC" — verified on-chain 2026-07-02: Base mainnet USDC's name() returns
# "USD Coin" (Sepolia's test contract happens to return "USDC"). Get this wrong and every
# real payment signature fails verification even though the 402 flow looks fine.
FEEDFACE_USDC_NAME="USD Coin"
FEEDFACE_USDC_VERSION=2

FEEDFACE_FACILITATOR_URL=https://x402.org/facilitator

# Ingredient pipelines (docs/11) — free self-serve keys, all instant/no-approval signups.
# Absent = that source's producer module logs a one-line skip and no-ops; nothing else breaks.
FRED_API_KEY=                # https://fred.stlouisfed.org/docs/api/api_key.html
CENSUS_API_KEY=               # https://api.census.gov/data/key_signup.html
DATA_GOV_API_KEY=             # https://api.data.gov/signup/ (BIS Entity List via data.trade.gov)
